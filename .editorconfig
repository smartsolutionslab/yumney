root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.cs]
indent_style = tab
max_line_length = 120

# StyleCop suppressions
dotnet_diagnostic.SA0001.severity = none
dotnet_diagnostic.SA1101.severity = none
dotnet_diagnostic.SA1200.severity = none
dotnet_diagnostic.SA1201.severity = none
dotnet_diagnostic.SA1309.severity = none
dotnet_diagnostic.SA1402.severity = none
dotnet_diagnostic.SA1600.severity = none
dotnet_diagnostic.SA1633.severity = none
dotnet_diagnostic.SA1501.severity = none
dotnet_diagnostic.SA1503.severity = none

# CA suppressions
dotnet_diagnostic.CA1000.severity = suggestion
dotnet_diagnostic.CA1716.severity = none
dotnet_diagnostic.CA1848.severity = suggestion
dotnet_sort_system_directives_first = true
csharp_using_directive_placement = outside_namespace
csharp_new_line_before_open_brace = all

# Braces: required, but allow single-line guard clauses (if + return/throw/continue/break)
csharp_prefer_braces = when_multiline:warning

# var: allowed when type is apparent, explicit type for built-in types and elsewhere
csharp_style_var_for_built_in_types = false:warning
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:warning

# Prefer explicit type for collection expressions (IDE0305)
dotnet_style_prefer_collection_expression = when_types_loosely_match:suggestion
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = true:suggestion
dotnet_style_null_propagation = true:warning
csharp_style_throw_expression = true:suggestion
csharp_style_namespace_declarations = file_scoped:warning

# Naming rules
dotnet_naming_rule.private_fields_must_be_camel_case.symbols = private_fields
dotnet_naming_rule.private_fields_must_be_camel_case.style = camel_case_style
dotnet_naming_rule.private_fields_must_be_camel_case.severity = warning
dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_style.camel_case_style.capitalization = camel_case

dotnet_naming_rule.interfaces_must_begin_with_i.symbols = interfaces
dotnet_naming_rule.interfaces_must_begin_with_i.style = begins_with_i
dotnet_naming_rule.interfaces_must_begin_with_i.severity = error
dotnet_naming_symbols.interfaces.applicable_kinds = interface
dotnet_naming_style.begins_with_i.required_prefix = I
dotnet_naming_style.begins_with_i.capitalization = pascal_case

dotnet_naming_rule.async_methods_must_end_with_async.symbols = async_methods
dotnet_naming_rule.async_methods_must_end_with_async.style = end_with_async
dotnet_naming_rule.async_methods_must_end_with_async.severity = warning
dotnet_naming_symbols.async_methods.applicable_kinds = method
dotnet_naming_symbols.async_methods.required_modifiers = async
dotnet_naming_style.end_with_async.required_suffix = Async
dotnet_naming_style.end_with_async.capitalization = pascal_case

[**/Migrations/*.cs]
generated_code = true

[*.{ts,tsx,js,jsx}]
indent_size = 2
max_line_length = 100

[*.{json,yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
