{
  "realm": "yumney",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "verifyEmail": true,
  "passwordPolicy": "length(8) and upperCase(1) and lowerCase(1) and digits(1)",
  "smtpServer": {
    "host": "mailpit",
    "port": "1025",
    "from": "noreply@yumney.dev",
    "fromDisplayName": "Yumney",
    "ssl": "false",
    "starttls": "false",
    "auth": "false"
  },
  "roles": {
    "realm": [
      {
        "name": "user",
        "description": "Standard user role"
      },
      {
        "name": "admin",
        "description": "Administrator role"
      }
    ]
  },
  "defaultRoles": ["user"],
  "clients": [
    {
      "clientId": "yumney-api",
      "name": "Yumney API",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "yumney-api-secret",
      "publicClient": false,
      "bearerOnly": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect"
    },
    {
      "clientId": "yumney-web",
      "name": "Yumney Web App",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://localhost:4200/*",
        "https://localhost:4200/*"
      ],
      "webOrigins": [
        "http://localhost:4200",
        "https://localhost:4200"
      ],
      "protocol": "openid-connect",
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "roles"
      ]
    }
  ],
  "users": [
    {
      "username": "testuser",
      "enabled": true,
      "email": "test@yumney.dev",
      "firstName": "Test",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "test",
          "temporary": false
        }
      ],
      "realmRoles": ["user"]
    },
    {
      "username": "admin",
      "enabled": true,
      "email": "admin@yumney.dev",
      "firstName": "Admin",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": ["user", "admin"]
    },
    {
      "username": "service-account-yumney-api",
      "enabled": true,
      "serviceAccountClientId": "yumney-api",
      "clientRoles": {
        "realm-management": ["manage-users"]
      }
    }
  ]
}
